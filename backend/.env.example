# ============================================
# TradeVision Pro — Local Configuration
# ============================================
# Copy this file to .env and fill in your values.
# All tokens/keys are generated locally and
# used only on your machine.
# ============================================

# App
APP_NAME=TradeVision Pro
VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# JWT Authentication (auto-generated, local-only)
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default admin credentials (change these)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tradevision2026
ADMIN_EMAIL=admin@tradevision.local

# Database (local SQLite by default)
DATABASE_URL=sqlite:///./tradevision.db

# Market Data API Keys
# Get free key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=demo

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
